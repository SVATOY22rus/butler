# Butler — конфигурация
# Скопируй этот файл в butler.env и измени значения

# Секретный ключ сессий Flask (обязательно смени на случайную строку)
BUTLER_SECRET_KEY=change-me-to-a-long-random-secret

# Путь к базе данных SQLite
# Оставь как есть — install.sh подставит правильный путь автоматически
BUTLER_DATABASE=

# Адрес и порт веб-интерфейса
BUTLER_HOST=0.0.0.0
BUTLER_PORT=5050

# Логин и пароль администратора
BUTLER_ADMIN_USER=admin
BUTLER_ADMIN_PASS=change-me-now

# Пути к файлам nftables (менять только если у тебя нестандартная конфигурация)
BUTLER_FIREWALL_TARGET=/etc/nftables.d/butler.nft
BUTLER_NFTABLES_CONF=/etc/nftables.conf
